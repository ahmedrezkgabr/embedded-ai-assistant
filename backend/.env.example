# Server port for Express backend
PORT=3000

# Base temporary directory used for uploads/transient STT+TTS files
TMP_DIR=/tmp

# Absolute upload directory for incoming multipart audio
UPLOAD_DIR=/tmp/ai-assistant/uploads

# Backend request log file path (morgan output)
LOG_FILE=/tmp/ai-assistant/backend.log

# llama-server HTTP base URL
LLM_BASE_URL=http://127.0.0.1:11434

# Model identifier sent to /v1/chat/completions model field
# Keep this aligned with llama-server loaded model naming
LLM_DEFAULT_MODEL=Qwen2.5-0.5B-Instruct-Q4_K_M.gguf

# LLM HTTP timeout in milliseconds
LLM_TIMEOUT=60000

# LLM default generation controls
LLM_MAX_TOKENS=128
LLM_TEMPERATURE=0
LLM_TOP_P=0.2
LLM_FREQUENCY_PENALTY=0
LLM_PRESENCE_PENALTY=0

# Optional JSON object passed as logit_bias to llama-server
# Example: {"1234":-100,"5678":-100}
LLM_LOGIT_BIAS_JSON=

# Strict system prompt injected into every LLM request
LLM_STRICT_SYSTEM_PROMPT=You are an embedded Linux voice assistant running offline. Always reply in English only using ASCII characters. Keep answers concise and factual.

# Speech-to-text executable and model
WHISPER_BIN=/absolute/path/to/embedded-ai-assistant/stt/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=/absolute/path/to/embedded-ai-assistant/stt/models/ggml-tiny.en.bin
WHISPER_TIMEOUT=30000

# Text-to-speech executable and voice model
PIPER_BIN=/absolute/path/to/embedded-ai-assistant/tts/bin/piper
PIPER_VOICE=/absolute/path/to/embedded-ai-assistant/tts/models/en_US-lessac-low.onnx

# Optional voice model directory for short voice IDs (en_US-lessac-low)
PIPER_VOICE_DIR=/absolute/path/to/embedded-ai-assistant/tts/models

# Optional espeak data directory for piper runtime
PIPER_ESPEAK_DATA=/absolute/path/to/embedded-ai-assistant/tts/bin/espeak-ng-data

# TTS process timeout in milliseconds
PIPER_TIMEOUT=20000

# Runtime mode
NODE_ENV=development

# Optional dynamic linker search path used by native binaries
LD_LIBRARY_PATH=
