PORT=3000
TMP_DIR=/tmp
UPLOAD_DIR=/tmp/ai-assistant/uploads
LOG_FILE=/tmp/ai-assistant/backend.log

LLM_BASE_URL=http://127.0.0.1:8080
LLM_DEFAULT_MODEL=qwen2.5-0.5b-instruct-q4_k_m
LLM_TIMEOUT=60000
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.0
LLM_TOP_P=0.2
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
# Optional JSON, example: {"1234":-100,"5678":-100}
LLM_LOGIT_BIAS_JSON=
# Optional override of strict English policy used as system prompt.
LLM_STRICT_SYSTEM_PROMPT=

WHISPER_BIN=/usr/bin/whisper-cli
WHISPER_MODEL=/usr/share/models/ggml-tiny.en.bin
WHISPER_TIMEOUT=30000

PIPER_BIN=/usr/bin/piper
PIPER_VOICE=/usr/share/models/en_US-lessac-low.onnx
PIPER_VOICE_DIR=/usr/share/models
PIPER_TIMEOUT=20000

NODE_ENV=development
